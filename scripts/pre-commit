#!/usr/bin/env bash
set -euo pipefail

STAGED=$(git diff --cached --name-only --diff-filter=ACM | grep '\.go$' || true)
if [ -z "$STAGED" ]; then
    exit 0
fi

echo "==> gofmt"
UNFORMATTED=$(gofmt -l $STAGED)
if [ -n "$UNFORMATTED" ]; then
    echo "Not formatted: $UNFORMATTED"
    echo "Run: gofmt -w ."
    exit 1
fi

echo "==> go vet"
go vet ./...

echo "==> go test"
go test ./... -count=1 -timeout 60s

echo "All checks passed."
